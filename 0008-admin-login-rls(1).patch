diff --git a/supabase/migrations/0003_admin_auth_rls.sql b/supabase/migrations/0003_admin_auth_rls.sql
new file mode 100644
index 0000000..8a52826
--- /dev/null
+++ b/supabase/migrations/0003_admin_auth_rls.sql
@@ -0,0 +1,51 @@
+-- Migration: habilita RLS nas tabelas offers e categories, com políticas
+-- separando leitura pública (site) de leitura/escrita administrativa
+-- (painel, exige login). Sem isso, a chave pública (anon key) sozinha
+-- permite ler/escrever tudo, mesmo sem passar pela tela de login.
+--
+-- Rode este arquivo no SQL Editor do Supabase.
+
+alter table public.offers enable row level security;
+alter table public.categories enable row level security;
+
+-- Leitura pública: qualquer visitante do site só vê ofertas ATIVAS.
+create policy "public_read_active_offers" on public.offers
+  for select
+  using (active = true);
+
+-- Categorias sempre foram públicas (usadas nos filtros do site) - mantém.
+create policy "public_read_categories" on public.categories
+  for select
+  using (true);
+
+-- Leitura administrativa: usuário logado (painel admin) vê TODAS as ofertas,
+-- inclusive inativas/rascunho.
+create policy "admin_read_all_offers" on public.offers
+  for select
+  to authenticated
+  using (true);
+
+-- Escrita de ofertas: só usuário logado pode inserir, editar ou excluir.
+create policy "admin_insert_offers" on public.offers
+  for insert
+  to authenticated
+  with check (true);
+
+create policy "admin_update_offers" on public.offers
+  for update
+  to authenticated
+  using (true)
+  with check (true);
+
+create policy "admin_delete_offers" on public.offers
+  for delete
+  to authenticated
+  using (true);
+
+-- Escrita de categorias: só usuário logado (preparado para o painel gerenciar
+-- categorias no futuro; hoje elas só são lidas, não editadas pelo painel).
+create policy "admin_write_categories" on public.categories
+  for all
+  to authenticated
+  using (true)
+  with check (true);
