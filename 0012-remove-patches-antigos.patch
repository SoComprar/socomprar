-+  if (!isSupabaseConfigured || !supabase) return () => {};
-+  const {
-+    data: { subscription },
-+  } = supabase.auth.onAuthStateChange((_event, session) => callback(session));
-+  return () => subscription.unsubscribe();
-+}
